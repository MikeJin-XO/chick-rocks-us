# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Neon Postgres (Postgres 17). Use the "Pooled connection" string from the Neon console.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Stripe (use test-mode keys while in the sandbox).
# Secret key: Stripe Dashboard → Developers → API keys → "Secret key" (starts sk_test_…)
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret for /api/stripe/webhook.
#   Local:  run `stripe listen --forward-to localhost:3000/api/stripe/webhook` → copy the whsec_… it prints
#   Prod:   Dashboard → Developers → Webhooks → add endpoint → copy "Signing secret"
STRIPE_WEBHOOK_SECRET="whsec_..."
# Optional: absolute site URL used for Stripe success/cancel redirects when the
# request origin can't be inferred (e.g. behind some proxies). Also used as the
# base URL for the logo in order emails.
# NEXT_PUBLIC_SITE_URL="https://chickrocksus.com"

# Resend — order receipt + owner notification emails (sent from the Stripe webhook).
# API key: resend.com → API Keys (starts re_…)
RESEND_API_KEY="re_..."
# Verified sender. The domain (chickrocksus.com) must be verified in Resend (DNS records).
ORDER_FROM_EMAIL="Chick Rocks <orders@chickrocksus.com>"
# Central inbox that receives a copy of every paid order.
ORDER_NOTIFICATION_EMAIL="orders@chickrocksus.com"

# Owner dashboard — single shared password for /admin/orders.
# Pick something long and random; it doubles as the HMAC secret for the session cookie.
ADMIN_PASSWORD="change-me-to-something-long-and-random"
