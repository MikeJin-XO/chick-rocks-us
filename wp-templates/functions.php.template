            'instagram' => (string) get_option('xo_dashboard_instagram_url', ''),
            'linkedin'  => (string) get_option('xo_dashboard_linkedin_url', ''),
            'tiktok'    => (string) get_option('xo_dashboard_tiktok_url', ''),
        ),
        'manager'      => (string) get_option('xo_dashboard_manager', ''),
        'headerCta'    => (string) get_option('xo_dashboard_header_cta', 'Order Online'),
    );

    if ($js) {
        wp_localize_script('<THEME_SLUG>-script', '<GLOBAL_NAME>', array(
            'postId'          => (int) $post_id,
            'pageData'        => $page_data,
            'allPageData'     => $all_page_data,
            'posts'           => $posts_data,
            'singlePost'      => $single_post,
            'isLoggedIn'      => current_user_can('edit_posts'),
            'restUrl'         => set_url_scheme(esc_url_raw(rest_url()), 'https'),
