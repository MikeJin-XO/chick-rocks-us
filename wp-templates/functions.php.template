/* 8. NEW-LEADS BADGE on the Leads menu */

function <THEME_SLUG_FN>_count_new_leads() {
    $q = new WP_Query(array(
        'post_type'      => 'catering_lead',
        'post_status'    => 'publish',
        'posts_per_page' => 1,
        'fields'         => 'ids',
        'no_found_rows'  => false,
        'meta_query'     => array(
            array(
                'key'     => 'lead_status',
                'value'   => 'new',
                'compare' => '=',
            ),
        ),
    ));
    return (int) $q->found_posts;
}

add_action('admin_menu', function () {
    global $menu;
    if (!is_array($menu)) return;
    $count = <THEME_SLUG_FN>_count_new_leads();
    if ($count <= 0) return;
    foreach ($menu as $key => $item) {
        if (!isset($item[2])) continue;
        if ($item[2] === 'edit.php?post_type=catering_lead') {
            $menu[$key][0] = sprintf(
                '%s <span class="awaiting-mod"><span class="pending-count">%d</span></span>',
                esc_html(strip_tags((string) $item[0])),
                $count
            );
            break;
        }
    }
}, 999);

/* 9. LEADS PDF EXPORT — jsPDF enqueue + AJAX endpoint + per-row button. */

add_action('admin_enqueue_scripts', function ($hook) {
    if ($hook !== 'edit.php') return;
    $post_type = sanitize_key($_GET['post_type'] ?? 'post');
    if ($post_type !== 'catering_lead') return;

    wp_enqueue_script('jspdf', 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js', array(), '2.5.1', true);
    wp_register_script('<THEME_SLUG_FN>-lead-pdf', '', array('jquery', 'jspdf'), '1.0.0', true);
    wp_enqueue_script('<THEME_SLUG_FN>-lead-pdf');

    wp_localize_script('<THEME_SLUG_FN>-lead-pdf', 'XODashboardLeadPdf', array(
        'ajaxUrl'  => admin_url('admin-ajax.php'),
        'nonce'    => wp_create_nonce('<THEME_SLUG_FN>_lead_pdf_nonce'),
        'siteName' => get_bloginfo('name'),
    ));

    wp_add_inline_script('<THEME_SLUG_FN>-lead-pdf', <THEME_SLUG_FN>_lead_pdf_inline_js());
});

function <THEME_SLUG_FN>_lead_pdf_inline_js() {
    return <<<JS
jQuery(function($) {
    function drawHeader(doc, d) {
        doc.setFillColor(212, 160, 23); // X.O. gold
        doc.rect(0, 0, 595, 80, 'F');
        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(20);
        doc.text(d.businessName || d.siteName || 'Catering Lead', 40, 38);
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(11);
        doc.text('Catering Lead Detail Report', 40, 60);
        doc.setTextColor(40, 40, 40);
    }
    function drawField(doc, y, label, value) {
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(10);
        doc.setTextColor(110, 110, 110);
        doc.text(String(label).toUpperCase(), 40, y);
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(12);
        doc.setTextColor(20, 20, 20);
        var v = value == null || value === '' ? '—' : String(value);
        var lines = doc.splitTextToSize(v, 515);
        doc.text(lines, 40, y + 16);
        return y + 16 + lines.length * 14 + 10;
    }
    function drawFooter(doc, d) {
        var h = doc.internal.pageSize.getHeight();
        doc.setDrawColor(220, 220, 220);
        doc.line(40, h - 50, 555, h - 50);
        doc.setFontSize(9);
        doc.setTextColor(120, 120, 120);
        doc.text('Lead #' + d.id + ' · Generated ' + new Date().toLocaleString(), 40, h - 32);
        if (d.storePhone || d.storeEmail) {
            doc.text((d.storePhone || '') + (d.storePhone && d.storeEmail ? ' · ' : '') + (d.storeEmail || ''), 40, h - 18);
        }
    }

    \$(document).on('click', '.xo-download-lead-pdf', function() {
        var \$btn = \$(this);
        var leadId = \$btn.data('lead-id');
        if (!leadId) return;
        \$btn.prop('disabled', true).text('Generating…');

        \$.post(XODashboardLeadPdf.ajaxUrl, {
            action: '<THEME_SLUG_FN>_get_lead_for_pdf',
            nonce:  XODashboardLeadPdf.nonce,
            lead_id: leadId,
        }).done(function(r) {
            if (!r || !r.success) {
                alert('Could not load lead data: ' + ((r && r.data && r.data.message) || 'unknown error'));
                \$btn.prop('disabled', false).text('Download PDF');
                return;
            }
            var d = r.data;
            d.siteName = XODashboardLeadPdf.siteName;
            var doc = new jspdf.jsPDF({ unit: 'pt', format: 'a4' });
            drawHeader(doc, d);
            var y = 110;
            y = drawField(doc, y, 'Name',         (d.firstName || '') + ' ' + (d.lastName || ''));
            y = drawField(doc, y, 'Email',        d.email);
            y = drawField(doc, y, 'Phone',        d.phone);
            y = drawField(doc, y, 'Party Size',   d.partySize);
            y = drawField(doc, y, 'Event Date',   d.eventDate);
            y = drawField(doc, y, 'Address',      d.address);
            y = drawField(doc, y, 'Submitted',    d.date);
            y = drawField(doc, y, 'Notification', d.notificationSent === 'yes' ? 'Sent to ' + (d.notificationTo || '') : 'Not sent');
            y = drawField(doc, y, 'Status',       d.status || 'new');
            drawFooter(doc, d);
            var safeName = ((d.firstName || 'lead') + '-' + (d.lastName || leadId)).toLowerCase().replace(/[^a-z0-9-]+/g, '-');
            doc.save('lead-' + safeName + '-' + leadId + '.pdf');
            \$btn.prop('disabled', false).text('Download PDF');
        }).fail(function(x) {
            alert('PDF request failed (' + x.status + ').');
            \$btn.prop('disabled', false).text('Download PDF');
        });
    });
});
JS;
}

add_action('wp_ajax_<THEME_SLUG_FN>_get_lead_for_pdf', function () {
    if (!current_user_can('edit_posts')) {
        wp_send_json_error(array('message' => 'Unauthorized'), 403);
    }
    check_ajax_referer('<THEME_SLUG_FN>_lead_pdf_nonce', 'nonce');

    $lead_id = isset($_POST['lead_id']) ? (int) $_POST['lead_id'] : 0;
    $lead = get_post($lead_id);
    if (!$lead || $lead->post_type !== 'catering_lead') {
        wp_send_json_error(array('message' => 'Lead not found'), 404);
    }

    wp_send_json_success(array(
        'id'               => $lead_id,
        'firstName'        => get_post_meta($lead_id, 'lead_first_name', true),
        'lastName'         => get_post_meta($lead_id, 'lead_last_name', true),
        'email'            => get_post_meta($lead_id, 'lead_email', true),
        'phone'            => get_post_meta($lead_id, 'lead_phone', true),
        'partySize'        => get_post_meta($lead_id, 'lead_party_size', true),
        'eventDate'        => get_post_meta($lead_id, 'lead_event_date', true),
        'address'          => get_post_meta($lead_id, 'lead_address', true),
        'status'           => get_post_meta($lead_id, 'lead_status', true) ?: 'new',
        'notificationSent' => get_post_meta($lead_id, 'lead_notification_sent', true),
        'notificationTo'   => get_post_meta($lead_id, 'lead_notification_to', true),
        'date'             => get_the_date('Y-m-d H:i', $lead_id),
        'businessName'     => (string) get_option('xo_dashboard_business_name', get_bloginfo('name')),
        'storeEmail'       => function_exists('<THEME_SLUG_FN>_get_contact_email') ? <THEME_SLUG_FN>_get_contact_email() : '',
        'storePhone'       => (string) get_option('xo_dashboard_store_phone', ''),
        'storeAddress'     => (string) get_option('xo_dashboard_store_address', ''),
    ));
});
