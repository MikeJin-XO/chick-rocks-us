    if (is_array($promoted_rows)) {
        foreach ($promoted_rows as $row) {
            $key = substr($row->option_name, strlen('xo_dashboard_default_'));
            if ($key !== '' && (!isset($default_media[$key]) || $default_media[$key] === '')) {
                $default_media[$key] = (string) $row->option_value;
