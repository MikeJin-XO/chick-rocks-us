/* Mirror Yoast's sitemap_index.xml into a physical /sitemap.xml so SE Ranking
 * and similar audit crawlers see a 200 instead of a 301 → /sitemap_index.xml.
 * If Yoast isn't installed, fall back to the dynamic /sitemap.xml that the
 * <THEME_SLUG_FN>_sitemap_handler emits (still a real 200). */
function <THEME_SLUG_FN>_generate_physical_sitemap() {
    $site_url = home_url();
    $post_mod = date('c');
    $page_mod = date('c');

    $resp = wp_remote_get($site_url . '/sitemap_index.xml', array('timeout' => 10, 'sslverify' => false));
    if (!is_wp_error($resp) && wp_remote_retrieve_response_code($resp) === 200) {
        $body = wp_remote_retrieve_body($resp);
        if (preg_match('~post-sitemap\.xml</loc>\s*<lastmod>([^<]+)</lastmod>~', $body, $m)) $post_mod = $m[1];
        if (preg_match('~page-sitemap\.xml</loc>\s*<lastmod>([^<]+)</lastmod>~', $body, $m)) $page_mod = $m[1];
        $xsl = '//' . parse_url($site_url, PHP_URL_HOST) . '/wp-content/plugins/wordpress-seo/css/main-sitemap.xsl';
        $xml  = '<?xml version="1.0" encoding="UTF-8"?>' . "\n";
        $xml .= '<?xml-stylesheet type="text/xsl" href="' . $xsl . '"?>' . "\n";
        $xml .= '<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">' . "\n";
        $xml .= "\t<sitemap>\n\t\t<loc>{$site_url}/post-sitemap.xml</loc>\n\t\t<lastmod>{$post_mod}</lastmod>\n\t</sitemap>\n";
        $xml .= "\t<sitemap>\n\t\t<loc>{$site_url}/page-sitemap.xml</loc>\n\t\t<lastmod>{$page_mod}</lastmod>\n\t</sitemap>\n";
        $xml .= '</sitemapindex>' . "\n";
        @file_put_contents(ABSPATH . 'sitemap.xml', $xml);
        return;
    }

    // No Yoast — snapshot the dynamic theme sitemap into a static file instead.
    $dynamic = wp_remote_get($site_url . '/sitemap.xml', array(
        'timeout'    => 10,
        'sslverify'  => false,
        'headers'    => array('User-Agent' => 'XO-Dashboard-Sitemap-Snapshot'),
        // Bypass our own handler so we get the dynamic XML, not the future static one
        'redirection' => 0,
    ));
    if (!is_wp_error($dynamic) && wp_remote_retrieve_response_code($dynamic) === 200) {
        $xml = wp_remote_retrieve_body($dynamic);
        if (is_string($xml) && strpos($xml, '<urlset') !== false) {
            @file_put_contents(ABSPATH . 'sitemap.xml', $xml);
        }
    }
}

function <THEME_SLUG_FN>_generate_physical_robots_txt() {
    $site_url = home_url();
    $robots  = "User-agent: *\nDisallow:\n\n";
    $robots .= "Sitemap: {$site_url}/sitemap_index.xml\n";
    $robots .= "Sitemap: {$site_url}/sitemap.xml\n";
    @file_put_contents(ABSPATH . 'robots.txt', $robots);
}

add_filter('robots_txt', function ($output) {
