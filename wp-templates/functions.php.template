/* Section 2: Refresh Text Content — global wipe of page-level text overrides, keeps images. */
function <THEME_SLUG_FN>_action_refresh_text_content() {
    global $wpdb;
    $where = array(
        "p.post_type = 'page'",
        "pm.meta_key NOT LIKE '\\_%'",
        "pm.meta_key NOT LIKE '%_img%'",
        "pm.meta_key NOT LIKE '%_image%'",
        "pm.meta_key NOT LIKE '%_bg%'",
        "pm.meta_key NOT LIKE '%_photo%'",
        "pm.meta_key NOT LIKE '%_icon%'",
        "pm.meta_key NOT LIKE '%_logo%'",
        "pm.meta_key NOT LIKE '%_banner%'",
    );
    $sql = "DELETE pm FROM {$wpdb->postmeta} pm
            INNER JOIN {$wpdb->posts} p ON p.ID = pm.post_id
            WHERE " . implode(' AND ', $where);
    $deleted = (int) $wpdb->query($sql);
    <THEME_SLUG_FN>_purge_caches();
    wp_safe_redirect(admin_url('admin.php?page=xo-dashboard-settings&text_refreshed=' . $deleted));
    exit;
}

/* Section 3: Promote Edited Images as Defaults — copy latest image overrides into
 * global `xo_dashboard_default_<key>` options + backfill missing pages. */
function <THEME_SLUG_FN>_action_promote_image_defaults() {
    $result = <THEME_SLUG_FN>_promote_image_defaults();
    wp_safe_redirect(admin_url(sprintf(
        'admin.php?page=xo-dashboard-settings&images_promoted=%d&page_updates=%d',
        (int) ($result['promoted_count'] ?? 0),
        (int) ($result['page_updates']   ?? 0)
    )));
    exit;
}

function <THEME_SLUG_FN>_promote_image_defaults() {
    global $wpdb;
    $promoted_count = 0;
    $page_updates   = 0;

    $image_keys = $wpdb->get_col(
        "SELECT DISTINCT pm.meta_key
         FROM {$wpdb->postmeta} pm
         INNER JOIN {$wpdb->posts} p ON p.ID = pm.post_id
         WHERE p.post_type = 'page'
           AND (pm.meta_key LIKE '%_img%'
                OR pm.meta_key LIKE '%_image%'
                OR pm.meta_key LIKE '%_bg%'
                OR pm.meta_key LIKE '%_photo%'
                OR pm.meta_key LIKE '%_icon%'
                OR pm.meta_key LIKE '%_logo%'
                OR pm.meta_key LIKE '%_banner%')"
    );

    foreach ((array) $image_keys as $key) {
        if (strpos($key, '_') === 0) continue;
        $row = $wpdb->get_row($wpdb->prepare(
            "SELECT pm.meta_value, pm.post_id
             FROM {$wpdb->postmeta} pm
             INNER JOIN {$wpdb->posts} p ON p.ID = pm.post_id
             WHERE pm.meta_key = %s
               AND pm.meta_value != ''
               AND p.post_type = 'page'
             ORDER BY p.post_modified DESC
             LIMIT 1",
            $key
        ));
        if (!$row || $row->meta_value === '') continue;

        update_option('xo_dashboard_default_' . $key, $row->meta_value);
        $promoted_count++;

        $missing_pages = $wpdb->get_col($wpdb->prepare(
            "SELECT p.ID FROM {$wpdb->posts} p
             LEFT JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = %s
             WHERE p.post_type = 'page'
               AND p.post_status = 'publish'
               AND (pm.meta_value IS NULL OR pm.meta_value = '')",
            $key
        ));
        foreach ($missing_pages as $pid) {
            update_post_meta($pid, $key, $row->meta_value);
            $page_updates++;
        }
    }

    <THEME_SLUG_FN>_purge_caches();
    return array('promoted_count' => $promoted_count, 'page_updates' => $page_updates);
}

