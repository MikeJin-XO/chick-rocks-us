function <THEME_SLUG_FN>_rest_get_page_data($request) {
    $path = $request->get_param('path') ?: '/';
    $post_id = url_to_postid($path);
    if (!$post_id && ($path === '/' || $path === '')) {
        $post_id = (int) get_option('page_on_front');
    }
    if (!$post_id) {
        return new WP_Error('not_found', 'Page not found', array('status' => 404));
    }
    $meta = get_post_meta($post_id);
    $page_data = array();
    foreach ($meta as $key => $values) {
        if (strpos($key, '_') !== 0 || $key === '_wp_page_template') {
            $page_data[$key] = $values[0];
        }
    }
    return array(
        'postId'     => $post_id,
        'pageData'   => $page_data,
        'isLoggedIn' => current_user_can('edit_posts'),
    );
}

function <THEME_SLUG_FN>_rest_save_page_data($request) {
    $params = $request->get_json_params();
    $post_id = intval($params['postId'] ?? 0);
    $page_data = $params['pageData'] ?? array();
    if (!$post_id) {
        return new WP_Error('invalid_id', 'Invalid Post ID', array('status' => 400));
    }
    if (!is_array($page_data)) {
        return new WP_Error('invalid_data', 'pageData must be an object', array('status' => 400));
    }
    foreach ($page_data as $key => $value) {
        if (strpos((string)$key, '_') === 0 && $key !== '_wp_page_template') continue;
        update_post_meta($post_id, sanitize_key($key), wp_kses_post((string)$value));
    }
    <THEME_SLUG_FN>_purge_caches();
    return array('success' => true, 'message' => 'Saved');
}

function <THEME_SLUG_FN>_is_image_meta_key($key) {
    if (!is_string($key) || $key === '') return false;
    return (bool) preg_match('/(img|image|bg|icon|logo|banner|photo)/i', $key);
}

function <THEME_SLUG_FN>_rest_refresh_text_content($request) {
    $params = $request->get_json_params();
    $post_id = intval($params['postId'] ?? 0);
    if (!$post_id || !get_post($post_id)) {
        return new WP_Error('invalid_id', 'Invalid Post ID', array('status' => 400));
    }
    global $wpdb;
    $keys = $wpdb->get_col($wpdb->prepare(
        "SELECT DISTINCT meta_key FROM {$wpdb->postmeta} WHERE post_id = %d", $post_id
    ));
    $deleted = 0;
    foreach ((array)$keys as $k) {
        if (strpos($k, '_') === 0) continue;
        if (<THEME_SLUG_FN>_is_image_meta_key($k)) continue;
        if (delete_post_meta($post_id, $k)) $deleted++;
    }
    wp_cache_delete($post_id, 'post_meta');
    clean_post_cache($post_id);
    <THEME_SLUG_FN>_purge_caches();
    return array('success' => true, 'deleted_count' => $deleted);
}

function <THEME_SLUG_FN>_purge_caches() {
    if (function_exists('sg_cachepress_purge_cache')) sg_cachepress_purge_cache();
    if (function_exists('wp_cache_flush'))            wp_cache_flush();
    if (function_exists('w3tc_flush_all'))            w3tc_flush_all();
    if (function_exists('wp_cache_clear_cache'))      wp_cache_clear_cache();
    if (function_exists('rocket_clean_domain'))       rocket_clean_domain();
    if (class_exists('LiteSpeed_Cache_API') && method_exists('LiteSpeed_Cache_API', 'purge_all')) {
        LiteSpeed_Cache_API::purge_all();
    }
    if (class_exists('WPSEO_Sitemaps_Cache') && method_exists('WPSEO_Sitemaps_Cache', 'clear')) {
        WPSEO_Sitemaps_Cache::clear();
    }
}

/* 4. AUTO-CREATE WP PAGES ON THEME ACTIVATION */

function <THEME_SLUG_FN>_create_pages() {
    $pages = array(
<WP_PAGES_ARRAY>
    );
    $front_id = 0;
    foreach ($pages as $p) {
        $existing = get_page_by_path($p['slug']);
        if ($existing) {
            if (!empty($p['front'])) $front_id = $existing->ID;
            continue;
        }
        $id = wp_insert_post(array(
            'post_title'     => $p['title'],
            'post_name'      => $p['slug'],
            'post_status'    => 'publish',
            'post_type'      => 'page',
            'post_content'   => '',
            'comment_status' => 'closed',
            'ping_status'    => 'closed',
        ));
        if ($id && !is_wp_error($id) && !empty($p['front'])) $front_id = $id;
    }
    if ($front_id) {
        update_option('show_on_front', 'page');
        update_option('page_on_front', $front_id);
    }
    // Posts live at /blog/{slug}/ so WP URLs match the React /blog/:slug route.
    if (get_option('permalink_structure') !== '/blog/%postname%/') {
        update_option('permalink_structure', '/blog/%postname%/');
    }
    flush_rewrite_rules();
}
add_action('after_switch_theme', '<THEME_SLUG_FN>_create_pages');

/* 4b. DYNAMIC SITEMAP — all published pages + posts at /sitemap.xml */

function <THEME_SLUG_FN>_sitemap_handler() {
    $req_uri  = isset($_SERVER['REQUEST_URI']) ? $_SERVER['REQUEST_URI'] : '';
    $req_path = $req_uri ? parse_url($req_uri, PHP_URL_PATH) : '';
    if ($req_path !== '/sitemap.xml') return;

    header('Content-Type: application/xml; charset=utf-8');
    header('X-Robots-Tag: noindex, follow', true);

    $home = trailingslashit(home_url('/'));
    echo '<?xml version="1.0" encoding="UTF-8"?>' . "\n";
    echo '<urlset xmlns="http://www.sitemaps.org/schemas/0.9">' . "\n";

    $pages = get_pages(array('sort_column' => 'menu_order', 'post_status' => 'publish'));
    foreach ($pages as $page) {
        $url = get_permalink($page->ID);
        if (!$url) continue;
        $lastmod = get_the_modified_date('c', $page->ID) ?: date('c');
        $prio = ((int) get_option('page_on_front') === (int) $page->ID) ? '1.0' : '0.8';
        echo '  <url><loc>' . esc_url($url) . '</loc><lastmod>' . esc_html($lastmod)
            . '</lastmod><changefreq>weekly</changefreq><priority>' . $prio . '</priority></url>' . "\n";
    }

    $posts = get_posts(array(
        'numberposts' => -1,
        'post_status' => 'publish',
        'post_type'   => 'post',
    ));
    foreach ($posts as $post) {
        $slug = $post->post_name ?: sanitize_title($post->post_title);
        if (!$slug) continue;
        $url = $home . 'blog/' . $slug . '/';
        $lastmod = get_the_modified_date('c', $post->ID) ?: date('c');
        echo '  <url><loc>' . esc_url($url) . '</loc><lastmod>' . esc_html($lastmod)
            . '</lastmod><changefreq>monthly</changefreq><priority>0.6</priority></url>' . "\n";
    }

    echo '</urlset>' . "\n";
    exit;
}
add_action('template_redirect', '<THEME_SLUG_FN>_sitemap_handler');

