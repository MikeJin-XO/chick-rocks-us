/* Reorder admin menu so X.O. Dashboard + Leads sit at the top, adjacent, right under Dashboard. */
add_action('admin_menu', function () {
    global $menu;
    if (!is_array($menu)) return;

    $xo = null;
    $leads = null;
    foreach ($menu as $key => $item) {
        if (!isset($item[2])) continue;
        if ($item[2] === 'xo-dashboard-settings') {
            $xo = $item;
            unset($menu[$key]);
        } elseif ($item[2] === 'edit.php?post_type=catering_lead') {
            $leads = $item;
            unset($menu[$key]);
        }
    }

    $reordered = array();
    $inserted = false;
    foreach ($menu as $item) {
        $reordered[] = $item;
        if (!$inserted && isset($item[2]) && $item[2] === 'index.php') {
            if ($xo)    $reordered[] = $xo;
            if ($leads) $reordered[] = $leads;
            $inserted = true;
        }
    }
    if (!$inserted) {
        $prefix = array();
        if ($xo)    $prefix[] = $xo;
        if ($leads) $prefix[] = $leads;
        $reordered = array_merge($prefix, $reordered);
    }
    $menu = $reordered;
}, 9999);

