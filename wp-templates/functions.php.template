function <THEME_SLUG_FN>_rest_submit_catering_lead($request) {
    $params = $request->get_json_params();
    if (!is_array($params)) $params = $request->get_params();

    $first      = sanitize_text_field((string) ($params['firstName']  ?? ''));
    $last       = sanitize_text_field((string) ($params['lastName']   ?? ''));
    $phone      = sanitize_text_field((string) ($params['phone']      ?? ''));
    $email      = sanitize_email((string)      ($params['email']      ?? ''));
    $party_size = sanitize_text_field((string) ($params['partySize']  ?? ''));
    $event_date = sanitize_text_field((string) ($params['eventDate']  ?? ''));
    $address    = sanitize_text_field((string) ($params['address']    ?? ''));
    $latitude   = sanitize_text_field((string) ($params['latitude']   ?? ''));
    $longitude  = sanitize_text_field((string) ($params['longitude']  ?? ''));

    if ($first === '' || $last === '' || $phone === '' || $email === '' || $address === '') {
        return new WP_Error('missing_fields', 'Please fill out all required fields.', array('status' => 400));
    }
    if (!is_email($email)) {
        return new WP_Error('invalid_email', 'Please enter a valid email address.', array('status' => 400));
    }

    $title = sprintf(
        'Catering Lead: %s %s (%s)',
        $first,
        $last,
        $event_date !== '' ? $event_date : current_time('Y-m-d H:i')
    );

    $post_id = wp_insert_post(array(
        'post_type'   => 'catering_lead',
        'post_title'  => $title,
        'post_status' => 'publish',
    ), true);

    if (is_wp_error($post_id) || !$post_id) {
        return new WP_Error('insert_failed', 'Could not save your request. Please try again.', array('status' => 500));
    }

    update_post_meta($post_id, 'lead_first_name', $first);
    update_post_meta($post_id, 'lead_last_name',  $last);
    update_post_meta($post_id, 'lead_phone',      $phone);
    update_post_meta($post_id, 'lead_email',      $email);
    update_post_meta($post_id, 'lead_party_size', $party_size);
    update_post_meta($post_id, 'lead_event_date', $event_date);
    update_post_meta($post_id, 'lead_address',    $address);
    update_post_meta($post_id, 'lead_latitude',   $latitude);
    update_post_meta($post_id, 'lead_longitude',  $longitude);
    update_post_meta($post_id, 'lead_status',     'new');
    update_post_meta($post_id, 'lead_submitted_ip', isset($_SERVER['REMOTE_ADDR']) ? sanitize_text_field($_SERVER['REMOTE_ADDR']) : '');

    // Reads xo_dashboard_contact_email first, falls back to the legacy option
    // and finally to admin_email — see <THEME_SLUG_FN>_get_contact_email().
    $notify_to = <THEME_SLUG_FN>_get_contact_email();
    $sent = false;
    if ($notify_to && is_email($notify_to)) {
        $subject = sprintf('[Chick Rocks] New catering lead: %s %s', $first, $last);
        $lines = array(
            'A new catering lead was submitted on chickrocksus.com.',
            '',
            'Name:        ' . $first . ' ' . $last,
            'Phone:       ' . $phone,
            'Email:       ' . $email,
            'Party size:  ' . $party_size,
            'Event date:  ' . $event_date,
            'Address:     ' . $address,
        );
        if ($latitude && $longitude) {
            $lines[] = 'Map:         https://www.openstreetmap.org/?mlat=' . rawurlencode($latitude) . '&mlon=' . rawurlencode($longitude) . '#map=17/' . rawurlencode($latitude) . '/' . rawurlencode($longitude);
        }
        $lines[] = '';
        $lines[] = 'View in admin: ' . admin_url('post.php?post=' . $post_id . '&action=edit');
        $body = implode("\n", $lines);
        $from_email = get_option('admin_email');
        $site_host  = wp_parse_url(home_url(), PHP_URL_HOST);
        if ($site_host && (!$from_email || !is_email($from_email))) {
            $from_email = 'wordpress@' . preg_replace('/^www\./i', '', $site_host);
        }
        $headers = array(
            'Content-Type: text/plain; charset=UTF-8',
            'From: X.O. Continental <' . $from_email . '>',
        );
        $sent = (bool) wp_mail($notify_to, $subject, $body, $headers);
    }
    update_post_meta($post_id, 'lead_notification_sent', $sent ? 'yes' : 'no');
    update_post_meta($post_id, 'lead_notification_to',   $notify_to);

    return array('success' => true, 'id' => (int) $post_id, 'notified' => $sent);
}

