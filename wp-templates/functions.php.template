        case 'lead_notify': {
            $sent = get_post_meta($post_id, 'lead_notification_sent', true);
            $to   = get_post_meta($post_id, 'lead_notification_to', true);
            if ($sent === 'yes') {
                echo '<span title="Sent to ' . esc_attr($to) . '" style="color:#1e8e3e;font-weight:600;">&#10003; Sent</span>';
