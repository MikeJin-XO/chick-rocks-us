        }
        case 'lead_status': {
            $status = get_post_meta($post_id, 'lead_status', true) ?: 'new';
            if ($status === 'reviewed') {
                echo '<span style="display:inline-block;padding:3px 10px;border-radius:999px;background:#e6f4ea;color:#1e8e3e;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.04em;">Reviewed</span>';
