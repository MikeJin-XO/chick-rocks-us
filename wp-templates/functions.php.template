function <THEME_SLUG_FN>_collect_post_meta($post_id) {
    $out = array();
    $meta = get_post_meta($post_id);
    foreach ($meta as $key => $values) {
        if (strpos($key, '_') !== 0 || $key === '_wp_page_template') {
            $out[$key] = $values[0];
        }
    }
    return $out;
}

function <THEME_SLUG_FN>_path_for_post_id($post_id) {
    $front_id = (int) get_option('page_on_front');
    if ((int) $post_id === $front_id) return '/';
    $permalink = get_permalink($post_id);
    if (!$permalink) return '';
    $parsed = parse_url($permalink, PHP_URL_PATH);
    if (!is_string($parsed) || $parsed === '') return '';
    $trimmed = '/' . trim($parsed, '/');
    return $trimmed;
}

function <THEME_SLUG_FN>_register_page_data(&$out, $path, $data) {
    if ($path === '') return;
    $out[$path] = $data;
    // location.pathname can be either `/menu` (React Router <Link>) or `/menu/`
    // (WP default permalinks) — register both so the cache always hits.
    if ($path !== '/' && substr($path, -1) !== '/') {
        $out[$path . '/'] = $data;
    }
}

function <THEME_SLUG_FN>_build_all_page_data() {
    $out = array();

    $pages = get_posts(array(
        'numberposts' => -1,
        'post_status' => 'publish',
        'post_type'   => 'page',
    ));
    foreach ($pages as $page) {
        $path = <THEME_SLUG_FN>_path_for_post_id($page->ID);
        <THEME_SLUG_FN>_register_page_data($out, $path, <THEME_SLUG_FN>_collect_post_meta($page->ID));
    }

    $posts = get_posts(array(
        'numberposts' => -1,
        'post_status' => 'publish',
        'post_type'   => 'post',
    ));
    foreach ($posts as $p) {
        $path = <THEME_SLUG_FN>_path_for_post_id($p->ID);
        <THEME_SLUG_FN>_register_page_data($out, $path, <THEME_SLUG_FN>_collect_post_meta($p->ID));
    }

    return $out;
}

function <THEME_SLUG_FN>_map_post_to_blog_shape($p) {
    $thumb_id = get_post_thumbnail_id($p->ID);
    $image = '';
    if ($thumb_id) {
        $img = wp_get_attachment_image_src($thumb_id, 'large');
        if (!$img) $img = wp_get_attachment_image_src($thumb_id, 'medium_large');
        if (!$img) $img = wp_get_attachment_image_src($thumb_id, 'full');
        if ($img && !empty($img[0])) $image = $img[0];
    }

    // Match the JS stripHtml/excerpt formatting in src/lib/data/blog-wp.ts so the
    // server-rendered shape and the REST-fetched shape are interchangeable.
    $excerpt_raw = has_excerpt($p) ? $p->post_excerpt : wp_trim_excerpt('', $p);
    $excerpt = wp_strip_all_tags((string) $excerpt_raw);
    $excerpt = str_replace('&nbsp;', ' ', $excerpt);
    $excerpt = preg_replace('/\s+/', ' ', $excerpt);
    $excerpt = trim($excerpt);

    $title = wp_strip_all_tags(get_the_title($p));

    // Render the post body the same way `the_content` would on a WP single template
    // (shortcodes, embeds, blocks) so it matches what /wp-json returns for the post.
    $body = apply_filters('the_content', $p->post_content);
    $body = str_replace(']]>', ']]&gt;', (string) $body);

    return array(
        'slug'    => $p->post_name ?: sanitize_title($p->post_title),
        'title'   => $title,
        'date'    => date_i18n('F j, Y', strtotime($p->post_date)),
        'image'   => $image,
        'excerpt' => $excerpt,
        'body'    => $body,
    );
}

function <THEME_SLUG_FN>_build_posts_data() {
    $out = array();
    $posts = get_posts(array(
        'numberposts' => -1,
        'post_status' => 'publish',
        'post_type'   => 'post',
        'orderby'     => 'date',
        'order'       => 'DESC',
    ));
    foreach ($posts as $p) {
        $out[] = <THEME_SLUG_FN>_map_post_to_blog_shape($p);
    }
    return $out;
}

