    // When rendering a single post (single.php), embed that post's full data so
    // BlogPost.tsx renders synchronously without a "Loading post…" flash.
    $single_post = null;
    if (is_single() && $post_id) {
        $cur_post = get_post($post_id);
        if ($cur_post) {
            $single_post = <THEME_SLUG_FN>_map_post_to_blog_shape($cur_post);
        }
    }

    $default_media = get_option('<THEME_SLUG_FN>_default_media', array());
    if (!is_array($default_media)) $default_media = array();

    // Section 3 of the X.O. Dashboard ("Promote Edited Images as Defaults") writes
    // per-key entries like `xo_dashboard_default_hero_img` into wp_options. Surface
    // them here so React's getDraftValue fallback chain (bridge.defaultMedia) picks
    // them up without per-page meta needing to exist.
    global $wpdb;
    $promoted_rows = $wpdb->get_results(
        "SELECT option_name, option_value
         FROM {$wpdb->options}
         WHERE option_name LIKE 'xo_dashboard_default_%'"
